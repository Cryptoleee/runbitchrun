rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Profile avatars: owner can write, anyone authed can read
    match /profiles/{userId}/avatar.jpg {
      allow read: if request.auth != null;
      allow write: if request.auth.uid == userId
        && request.resource.size < 2 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }
    // Run photos: owner can write, anyone authed can read
    // Code uses flat path: runs/{userId}/{photoId}_full.jpg and _thumb.jpg
    match /runs/{userId}/{filename} {
      allow read: if request.auth != null;
      allow write: if request.auth.uid == userId
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }
  }
}
